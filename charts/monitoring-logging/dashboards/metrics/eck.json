        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(kube_pod_status_phase{namespace=\"podiumd\",pod=~\"kiss-ent-.*\",phase=\"Running\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
