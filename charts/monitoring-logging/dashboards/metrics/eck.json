          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "PVC Usage (Elasticsearch)",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
