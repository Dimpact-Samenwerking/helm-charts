      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(clamav_files_scanned_total{namespace=\"podiumd\"}[5m])",
          "legendFormat": "files/s",
          "refId": "A"
