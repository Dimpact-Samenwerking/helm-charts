        "uid": "${datasource}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (job) (rate(http_server_duration_milliseconds_count{job=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
