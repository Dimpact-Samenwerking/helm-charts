{
  "uid": "podiumd-django-red",
  "title": "PodiumD - Django Services RED",
  "description": "Rate / Errors / Duration for PodiumD Django services (OpenTelemetry via job label)",
  "tags": [
    "podiumd",
    "otel",
    "red",
    "django"
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "query": "prometheus",
        "refresh": 1
      },
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(http_server_duration_milliseconds_count, job)",
        "query": "label_values(http_server_duration_milliseconds_count, job)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": [],
