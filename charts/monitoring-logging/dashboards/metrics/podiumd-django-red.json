      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
