          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(redis_net_input_bytes_total{job=\"podiumd/redis-ha\"}[1m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "DB Keys",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
