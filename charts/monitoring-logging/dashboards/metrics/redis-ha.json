            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "redis_db_keys{job=\"podiumd/redis-ha\"}",
          "legendFormat": "{{db}} {{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Expired Keys / sec",
      "gridPos": {
        "x": 12,
        "y": 27,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
