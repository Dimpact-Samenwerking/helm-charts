    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Request Rate by pod",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (pod) (rate(http_server_requests_seconds_count{namespace=\"podiumd\",pod=~\"keycloak.*\"}[5m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP p95 / p50 Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(http_server_requests_seconds_max{namespace=\"podiumd\",pod=~\"keycloak.*\"})",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(http_server_requests_seconds_sum{namespace=\"podiumd\",pod=~\"keycloak.*\"}[5m])) / sum(rate(http_server_requests_seconds_count{namespace=\"podiumd\",pod=~\"keycloak.*\"}[5m]))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ]
    },
    {
